---
// Navbar Component - Reusable across all pages
// Place at: src/components/Navbar.astro
---

<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/snd.png" alt="SND" onerror="this.parentNode.innerHTML='<div class=\'logo-fallback\'>SND</div>';" />
  </a>
  
  <!-- Desktop Navigation -->
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About Us</a></li>
    <li><a href="/blog">Blog</a></li>

  </ul>
  
  <a href="/contact" class="nav-cta">Get in Touch</a>
  
  <!-- Mobile Hamburger Button -->
  <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-header">
    <div class="mobile-menu-logo">
      <img src="/snd.png" alt="SND" height="40" />
    </div>
    <button class="mobile-menu-close" id="closeMenuBtn" aria-label="Close Menu">✕</button>
  </div>
  
  <ul class="mobile-nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About Us</a></li>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/remi">Remi App</a></li>
    <li><a href="/contact">Contact</a></li>
    <li><a href="/terms">Terms</a></li>
    <li><a href="/privacy">Privacy</a></li>
  </ul>
  

</div>

<!-- Overlay -->
<div class="menu-overlay" id="menuOverlay"></div>

<style>
  /* Desktop Navbar Styles */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 4rem;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(52,57,64,0.08);
    transition: background 0.25s, box-shadow 0.25s;
  }
  
  nav.scrolled {
    box-shadow: 0 8px 20px rgba(0,0,0,0.02);
    background: rgba(255,255,255,0.98);
  }
  
  .nav-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .nav-logo img { height: 44px; width: auto; }
  
  .logo-fallback {
    font-family: var(--font-display);
    font-weight: 700; font-size: 1.5rem;
    color: var(--snd-dark); background: var(--snd-light);
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
  }
  
  .nav-links { 
    display: flex; 
    align-items: center; 
    gap: 2rem; 
    list-style: none; 
  }
  
  .nav-links a { 
    color: var(--snd-dark); 
    text-decoration: none; 
    font-size: 0.9rem; 
    font-weight: 500; 
    transition: color 0.2s; 
  }
  
  .nav-links a:hover { color: var(--snd-black); }
  
  .nav-cta {
    background: var(--snd-black); 
    color: var(--snd-white);
    border: none; 
    padding: 0.6rem 1.4rem;
    border-radius: 40px; 
    font-size: 0.85rem; 
    font-weight: 600;
    letter-spacing: 0.01em; 
    cursor: pointer; 
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  
  .nav-cta:hover { background: #2c2c2c; transform: scale(1.02); }
  
  /* Hamburger Button */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1001;
  }
  
  .hamburger span {
    width: 22px;
    height: 2px;
    background: var(--snd-dark);
    border-radius: 2px;
    transition: 0.3s ease;
  }
  
  /* Mobile Menu Overlay - Compact and Clean */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 85%;
    max-width: 320px;
    height: 100vh;
    background: var(--snd-white);
    z-index: 2000;
    box-shadow: -5px 0 25px rgba(0,0,0,0.1);
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
    padding: 1.2rem;
  }
  
  .mobile-menu.active {
    right: 0;
  }
  
  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--snd-light);
  }
  
  .mobile-menu-logo img {
    height: 36px;
    width: auto;
  }
  
  .mobile-menu-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--snd-dark);
    padding: 5px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  /* Mobile Navigation Links - Tight Spacing */
  .mobile-nav-links {
    list-style: none;
    flex: 1;
    margin: 0;
    padding: 0;
  }
  
  .mobile-nav-links li {
    margin-bottom: 0.8rem;
    border-bottom: 1px solid rgba(52,57,64,0.05);
  }
  
  .mobile-nav-links a {
    color: var(--snd-dark);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.2s;
    display: block;
    padding: 0.6rem 0;
  }
  
  .mobile-nav-links a:hover {
    color: var(--snd-black);
    transform: translateX(5px);
  }
  
  /* Footer with Get in Touch Button - Clearly Visible */
  .mobile-menu-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--snd-light);
  }
  
  .mobile-cta {
    background: var(--snd-black);
    color: var(--snd-white);
    padding: 0.75rem 1.2rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    display: block;
    text-align: center;
    width: 100%;
    transition: background 0.2s, transform 0.2s;
  }
  
  .mobile-cta:hover {
    background: #2c2c2c;
    transform: scale(1.02);
  }
  
  /* Overlay Background */
  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 1999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  
  .menu-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  
  /* Responsive */
  @media (max-width: 900px) {
    nav { padding: 0.8rem 1.2rem; }
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
  
  @media (min-width: 901px) {
    .mobile-menu,
    .menu-overlay {
      display: none;
    }
  }
</style>

<script>
  // Mobile menu functionality
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  const closeMenuBtn = document.getElementById('closeMenuBtn');
  const menuOverlay = document.getElementById('menuOverlay');
  
  // Function to open menu
  function openMenu() {
    mobileMenu.classList.add('active');
    if (menuOverlay) menuOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  
  // Function to close menu
  function closeMenu() {
    mobileMenu.classList.remove('active');
    if (menuOverlay) menuOverlay.classList.remove('active');
    document.body.style.overflow = '';
  }
  
  // Event listeners
  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', openMenu);
  }
  
  if (closeMenuBtn) {
    closeMenuBtn.addEventListener('click', closeMenu);
  }
  
  if (menuOverlay) {
    menuOverlay.addEventListener('click', closeMenu);
  }
  
  // Close menu when clicking on a link
  const mobileLinks = document.querySelectorAll('.mobile-nav-links a');
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
  
  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu && mobileMenu.classList.contains('active')) {
      closeMenu();
    }
  });
  
  // Navbar scroll effect
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    if (nav) {
      nav.classList.toggle('scrolled', window.scrollY > 30);
    }
  });
</script>