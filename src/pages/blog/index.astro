---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

// Get all blog posts
const allPosts = await getCollection('blog');

// Debug: Log to see what's happening
console.log('=== BLOG DEBUG ===');
console.log('Total posts found:', allPosts.length);

if (allPosts.length > 0) {
  allPosts.forEach(post => {
    // In Astro v6, use 'id' instead of 'slug'
    console.log('Post id:', post.id, 'Title:', post.data.title);
  });
}

// Sort by date (newest first)
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog — SND | Insights & Updates</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --snd-dark:   #343940;
      --snd-light:  #CFCFD3;
      --snd-black:  #0d0d0d;
      --snd-white:  #ffffff;
      --remi-blue:  #535FFD;
      --remi-amber: #FDAC1B;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'Skia', 'Inter', 'Helvetica Neue', system-ui, sans-serif;
    }

    body {
      background: var(--snd-white);
      color: var(--snd-black);
      font-family: var(--font-body);
      line-height: 1.5;
    }

    .blog-hero {
      background: linear-gradient(135deg, var(--snd-dark) 0%, #2a2f35 100%);
      padding: 10rem 4rem 5rem;
      text-align: center;
    }

    .blog-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      color: white;
      margin-bottom: 1rem;
    }

    .blog-hero p {
      color: rgba(255,255,255,0.7);
      max-width: 600px;
      margin: 0 auto;
      font-size: 1.1rem;
    }

    .blog-grid-section {
      padding: 5rem 4rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 2rem;
    }

    .blog-card {
      background: var(--snd-white);
      border: 1px solid var(--snd-light);
      border-radius: 24px;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .blog-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1);
    }

    .blog-image {
      width: 100%;
      height: 220px;
      overflow: hidden;
      background: var(--snd-light);
    }

    .blog-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .blog-card:hover .blog-image img {
      transform: scale(1.05);
    }

    .blog-content {
      padding: 1.5rem;
    }

    .blog-meta {
      display: flex;
      gap: 1rem;
      margin-bottom: 0.75rem;
      font-size: 0.75rem;
      color: #8a9bb0;
    }

    .blog-date {
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .blog-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.75rem;
    }

    .blog-tag {
      background: rgba(52,57,64,0.08);
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.7rem;
      color: var(--snd-dark);
    }

    .blog-content h2 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--snd-black);
      line-height: 1.3;
    }

    .blog-content p {
      color: #5f6c7a;
      font-size: 0.9rem;
      line-height: 1.6;
      margin-bottom: 1rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .read-more {
      color: var(--snd-dark);
      font-weight: 600;
      font-size: 0.85rem;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
    }

    .read-more:hover {
      gap: 0.5rem;
    }

    .empty-state {
      text-align: center;
      padding: 4rem;
      background: #f9fafb;
      border-radius: 24px;
      color: #8a9bb0;
    }

    @media (max-width: 900px) {
      .blog-hero { padding: 8rem 1.5rem 4rem; }
      .blog-grid-section { padding: 3rem 1.5rem; }
      .blog-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <Navbar />

  <div class="blog-hero">
    <h1>Insights & Updates</h1>
    <p>Stories, ideas, and perspectives from the SND team</p>
  </div>

  <div class="blog-grid-section">
    {sortedPosts.length === 0 ? (
      <div class="empty-state">
        <p>📝 No blog posts yet. Check back soon!</p>
        <p style="margin-top: 1rem; font-size: 0.8rem;">Make sure your blog posts are in <code>src/content/blog/</code></p>
      </div>
    ) : (
      <div class="blog-grid">
        {sortedPosts.map((post) => {
          // In Astro v6, use 'id' (without .md extension) as the slug
          const postSlug = post.id.replace(/\.md$/, '');
          console.log('Rendering link to:', postSlug);
          return (
            <a href={`/blog/${postSlug}`} class="blog-card">
              <div class="blog-image">
                <img 
                  src={post.data.image || '/placeholder.jpg'} 
                  alt={post.data.title}
                  onerror="this.src='https://placehold.co/600x400/e2e8f0/475569?text=' + encodeURIComponent(post.data.title)"
                />
              </div>
              <div class="blog-content">
                <div class="blog-meta">
                  <span class="blog-date">{post.data.pubDate}</span>
                  <span>•</span>
                  <span>by {post.data.author}</span>
                </div>
                <div class="blog-tags">
                  {post.data.tags?.slice(0, 2).map((tag) => (
                    <span class="blog-tag">#{tag}</span>
                  ))}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-more">Read More →</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

  <Footer />

</body>
</html>