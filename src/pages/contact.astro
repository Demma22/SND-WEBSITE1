---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us — SND</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --snd-dark:   #343940;
      --snd-light:  #CFCFD3;
      --snd-black:  #0d0d0d;
      --snd-white:  #ffffff;
      --remi-blue:  #535FFD;
      --remi-amber: #FDAC1B;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'Inter', 'Helvetica Neue', system-ui, sans-serif;
    }

    body {
      background: var(--snd-white);
      color: var(--snd-black);
      font-family: var(--font-body);
      line-height: 1.5;
    }

    /* Contact Hero */
    .contact-hero {
      background: linear-gradient(135deg, var(--snd-dark) 0%, #2a2f35 100%);
      padding: 10rem 4rem 5rem;
      text-align: center;
    }

    .contact-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      color: white;
      margin-bottom: 1rem;
    }

    .contact-hero p {
      color: rgba(255,255,255,0.7);
      max-width: 600px;
      margin: 0 auto;
      font-size: 1.1rem;
    }

    /* Contact Content */
    .contact-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 5rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    /* Contact Info Section */
    .contact-info h2,
    .contact-form h2 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .contact-info > p {
      color: #5f6c7a;
      margin-bottom: 2rem;
      line-height: 1.7;
    }

    /* Contact Details */
    .contact-details {
      margin-bottom: 2rem;
    }

    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .contact-icon {
      width: 48px;
      height: 48px;
      background: rgba(52,57,64,0.08);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      flex-shrink: 0;
    }

    .contact-item h3 {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      color: var(--snd-black);
      margin-bottom: 0.25rem;
    }

    .contact-item p,
    .contact-item a {
      color: #5f6c7a;
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-item a:hover {
      color: var(--snd-dark);
    }

    /* Social Links */
    .social-links {
      margin-top: 2rem;
    }

    .social-links h3 {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .social-icons {
      display: flex;
      gap: 1rem;
    }

    .social-icon {
      width: 44px;
      height: 44px;
      background: var(--snd-light);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: var(--snd-dark);
      font-size: 1.1rem;
      font-weight: 600;
      transition: all 0.2s;
    }

    .social-icon:hover {
      background: var(--snd-dark);
      color: white;
      transform: translateY(-3px);
    }

    /* Contact Form */
    .contact-form {
      background: #f9fafb;
      padding: 2rem;
      border-radius: 24px;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--snd-dark);
      margin-bottom: 0.5rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 1px solid var(--snd-light);
      border-radius: 12px;
      font-family: var(--font-body);
      font-size: 0.9rem;
      transition: border-color 0.2s;
      background: white;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--snd-dark);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }

    .submit-btn {
      background: var(--snd-black);
      color: white;
      border: none;
      padding: 0.9rem 1.8rem;
      border-radius: 40px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, background 0.2s;
      width: 100%;
    }

    .submit-btn:hover {
      background: #2c2c2c;
      transform: translateY(-2px);
    }

    /* Success Message */
    .success-message {
      background: #d1fae5;
      color: #065f46;
      padding: 1rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      text-align: center;
      font-size: 0.9rem;
    }

    .error-message {
      background: #fee2e2;
      color: #991b1b;
      padding: 1rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      text-align: center;
      font-size: 0.9rem;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .contact-hero { padding: 8rem 1.5rem 4rem; }
      .contact-content { padding: 3rem 1.5rem; grid-template-columns: 1fr; gap: 3rem; }
    }
  </style>
</head>
<body>

  <Navbar />

  <!-- Hero Section -->
  <div class="contact-hero">
    <h1>Let's Talk</h1>
    <p>Have a project in mind? We'd love to hear from you.</p>
  </div>

  <!-- Contact Content -->
  <div class="contact-content">
    
    <!-- Left Column: Contact Info -->
    <div class="contact-info">
      <h2>Get in Touch</h2>
      <p>Whether you have a question, a project idea, or just want to say hello — we're here for you.</p>
      
      <div class="contact-details">
        
        <!-- Phone 1 -->
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <h3>Phone (Primary)</h3>
            <a href="tel:+256742072661">0742072661</a>
          </div>
        </div>
        
        <!-- Phone 2 -->
        <div class="contact-item">
          <div class="contact-icon">📱</div>
          <div>
            <h3>Phone (Secondary)</h3>
            <a href="tel:+256780288715">0780288715</a>
          </div>
        </div>
        
        <!-- Email (optional) -->
        <div class="contact-item">
          <div class="contact-icon">✉️</div>
          <div>
            <h3>Email</h3>
            <a href="mailto:hello@snd.com">hello@snd.com</a>
          </div>
        </div>
        
        <!-- Location (optional) -->
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <h3>Location</h3>
            <p>Kampala, Uganda</p>
          </div>
        </div>
        
      </div>
      
      <!-- Social Media Links -->
      <div class="social-links">
        <h3>Follow Us</h3>
        <div class="social-icons">
          <a href="#" class="social-icon" id="instagram-link" target="_blank" rel="noopener">IG</a>
          <a href="#" class="social-icon" id="tiktok-link" target="_blank" rel="noopener">TK</a>
          <a href="#" class="social-icon" id="threads-link" target="_blank" rel="noopener">TH</a>
          <a href="#" class="social-icon" id="twitter-link" target="_blank" rel="noopener">𝕏</a>
          <a href="#" class="social-icon" id="linkedin-link" target="_blank" rel="noopener">IN</a>
        </div>
      </div>
    </div>
    
    <!-- Right Column: Contact Form -->
    <div class="contact-form">
      <h2>Send a Message</h2>
      
      <form id="contactForm" method="POST" netlify>
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required />
        </div>
        
        <div class="form-group">
          <label for="phone">Phone Number (optional)</label>
          <input type="tel" id="phone" name="phone" />
        </div>
        
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        
        <button type="submit" class="submit-btn">Send Message →</button>
      </form>
    </div>
    
  </div>

  <Footer />

  <script>
    // Social media links - REPLACE THESE WITH YOUR ACTUAL LINKS
    const socialLinks = {
      instagram: "https://www.instagram.com/snd.graphiix/",
      tiktok: "https://www.tiktok.com/@snd",
      threads: "https://www.threads.net/@snd",
      twitter: "https://twitter.com/snd",
      linkedin: "https://www.linkedin.com/company/snd"
    };
    
    // Update social media links
    const instagramLink = document.getElementById('instagram-link');
    const tiktokLink = document.getElementById('tiktok-link');
    const threadsLink = document.getElementById('threads-link');
    const twitterLink = document.getElementById('twitter-link');
    const linkedinLink = document.getElementById('linkedin-link');
    
    if (instagramLink) instagramLink.href = socialLinks.instagram;
    if (tiktokLink) tiktokLink.href = socialLinks.tiktok;
    if (threadsLink) threadsLink.href = socialLinks.threads;
    if (twitterLink) twitterLink.href = socialLinks.twitter;
    if (linkedinLink) linkedinLink.href = socialLinks.linkedin;
    
    // Form submission handling
    const form = document.getElementById('contactForm');
    
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const submitBtn = form.querySelector('.submit-btn');
        const originalText = submitBtn.textContent;
        
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;
        
        try {
          // For Netlify forms
          const response = await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(formData).toString()
          });
          
          if (response.ok) {
            form.innerHTML = '<div class="success-message">✅ Thank you! Your message has been sent. We\'ll get back to you soon.</div>';
          } else {
            throw new Error('Form submission failed');
          }
        } catch (error) {
          // If Netlify forms not configured, show a message
          form.innerHTML = `
            <div class="error-message">
              ⚠️ Form submission failed. Please email us directly at hello@snd.com or call ${phoneNumbers.primary}.
            </div>
            <div class="form-group" style="margin-top: 1rem;">
              <p style="color: #5f6c7a; font-size: 0.85rem;">You can also reach us at:</p>
              <p style="font-weight: 600;">📞 0742072661</p>
              <p style="font-weight: 600;">📞 0780288715</p>
            </div>
          `;
        }
      });
    }
  </script>

</body>
</html>