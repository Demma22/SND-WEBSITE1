---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us — SND | Let's Talk">
  <Navbar />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --snd-dark:   #343940;
      --snd-light:  #CFCFD3;
      --snd-black:  #0d0d0d;
      --snd-white:  #ffffff;
      --remi-blue:  #535FFD;
      --remi-amber: #FDAC1B;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'Inter', 'Helvetica Neue', system-ui, sans-serif;
    }

    body {
      background: var(--snd-white);
      color: var(--snd-black);
      font-family: var(--font-body);
      line-height: 1.5;
    }

    /* Contact Hero */
    .contact-hero {
      background: linear-gradient(135deg, var(--snd-dark) 0%, #2a2f35 100%);
      padding: 10rem 4rem 5rem;
      text-align: center;
    }

    .contact-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      color: white;
      margin-bottom: 1rem;
    }

    .contact-hero p {
      color: rgba(255,255,255,0.7);
      max-width: 600px;
      margin: 0 auto;
      font-size: 1.1rem;
    }

    /* Contact Content */
    .contact-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 5rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    /* Contact Info Section */
    .contact-info h2,
    .contact-form h2 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .contact-info > p {
      color: #5f6c7a;
      margin-bottom: 2rem;
      line-height: 1.7;
    }

    /* Contact Details */
    .contact-details {
      margin-bottom: 2rem;
    }

    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .contact-icon {
      width: 48px;
      height: 48px;
      background: rgba(52,57,64,0.08);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-icon img {
      width: 22px;
      height: 22px;
      object-fit: contain;
    }

    .contact-item h3 {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      color: var(--snd-black);
      margin-bottom: 0.25rem;
    }

    .contact-item p,
    .contact-item a {
      color: #5f6c7a;
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-item a:hover {
      color: var(--snd-dark);
    }

    /* Social Links */
    .social-links {
      margin-top: 2rem;
    }

    .social-links h3 {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .social-icons {
      display: flex;
      gap: 1rem;
    }

    .social-icon {
      width: 44px;
      height: 44px;
      background: var(--snd-light);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .social-icon img {
      width: 20px;
      height: 20px;
      object-fit: contain;
    }

    .social-icon:hover {
      background: var(--snd-dark);
      transform: translateY(-3px);
    }

    .social-icon:hover img {
      filter: brightness(0) invert(1);
    }

    /* Contact Form */
    .contact-form {
      background: #f9fafb;
      padding: 2rem;
      border-radius: 24px;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--snd-dark);
      margin-bottom: 0.5rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.8rem 1rem;
      border: 1px solid var(--snd-light);
      border-radius: 12px;
      font-family: var(--font-body);
      font-size: 0.9rem;
      transition: border-color 0.2s;
      background: white;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--snd-dark);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }

    .submit-btn {
      background: var(--snd-black);
      color: white;
      border: none;
      padding: 0.9rem 1.8rem;
      border-radius: 40px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, background 0.2s;
      width: 100%;
    }

    .submit-btn:hover {
      background: #2c2c2c;
      transform: translateY(-2px);
    }

    /* Success/Error Messages */
    .form-message {
      padding: 1rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      text-align: center;
      font-size: 0.9rem;
      display: none;
    }

    .form-message.success {
      background: #d1fae5;
      color: #065f46;
      display: block;
    }

    .form-message.error {
      background: #fee2e2;
      color: #991b1b;
      display: block;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .contact-hero { padding: 8rem 1.5rem 4rem; }
      .contact-content { padding: 3rem 1.5rem; grid-template-columns: 1fr; gap: 3rem; }
    }
  </style>

  <!-- Hero Section -->
  <div class="contact-hero">
    <h1>Let's Talk</h1>
    <p>Have a project in mind? We'd love to hear from you.</p>
  </div>

  <!-- Contact Content -->
  <div class="contact-content">
    
    <!-- Left Column: Contact Info -->
    <div class="contact-info">
      <h2>Get in Touch</h2>
      <p>Whether you have a question, a project idea, or just want to say hello — we're here for you.</p>
      
      <div class="contact-details">
        
        <!-- Phone 1 -->
        <div class="contact-item">
          <div class="contact-icon">
            <img src="/phone.svg" alt="Phone" onerror="this.style.display='none'; this.parentNode.innerHTML='📞';" />
          </div>
          <div>
            <h3>Phone (Primary)</h3>
            <a href="tel:+256742072661">0742072661</a>
          </div>
        </div>
        
        <!-- Phone 2 -->
        <div class="contact-item">
          <div class="contact-icon">
            <img src="/phone.svg" alt="Phone" onerror="this.style.display='none'; this.parentNode.innerHTML='📱';" />
          </div>
          <div>
            <h3>Phone (Secondary)</h3>
            <a href="tel:+256780288715">0780288715</a>
          </div>
        </div>
        
        <!-- Email -->
        <div class="contact-item">
          <div class="contact-icon">
            <img src="/mail.svg" alt="Email" onerror="this.style.display='none'; this.parentNode.innerHTML='✉️';" />
          </div>
          <div>
            <h3>Email</h3>
            <a href="mailto:hello@snd.com">hello@snd.com</a>
          </div>
        </div>
        
        <!-- Location -->
        <div class="contact-item">
          <div class="contact-icon">
            <img src="/pin.svg" alt="Location" onerror="this.style.display='none'; this.parentNode.innerHTML='📍';" />
          </div>
          <div>
            <h3>Location</h3>
            <p>Kampala, Uganda</p>
          </div>
        </div>
        
      </div>
      
      <!-- Social Media Links (same as footer) -->
      <div class="social-links">
        <h3>Follow Us</h3>
        <div class="social-icons">
          <a href="https://www.instagram.com/snd.graphiix/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
            <img src="/instagram.svg" alt="Instagram" onerror="this.style.display='none'; this.parentNode.innerHTML='IG';" />
          </a>
          <a href="https://www.tiktok.com/@snd.store0?lang=en" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="TikTok">
            <img src="/tiktok.svg" alt="TikTok" onerror="this.style.display='none'; this.parentNode.innerHTML='TK';" />
          </a>
          <a href="https://www.threads.com/@snd.graphiix?xmt=AQF0s0BLGM7T1G-QmMiLX5rr4xiB9WsJsEYTjw51EnCosLg" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Threads">
            <img src="/threads.svg" alt="Threads" onerror="this.style.display='none'; this.parentNode.innerHTML='TH';" />
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="X">
            <img src="/x.svg" alt="X" onerror="this.style.display='none'; this.parentNode.innerHTML='𝕏';" />
          </a>
        </div>
      </div>
    </div>
    
    <!-- Right Column: Contact Form -->
    <div class="contact-form">
      <h2>Send a Message</h2>
      
      <div id="formMessage" class="form-message"></div>
      
      <form id="contactForm">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required />
        </div>
        
        <div class="form-group">
          <label for="phone">Phone Number (optional)</label>
          <input type="tel" id="phone" name="phone" />
        </div>
        
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        
        <button type="submit" class="submit-btn">Send Message →</button>
      </form>
    </div>
  <Footer />

   <script>
    const form = document.getElementById('contactForm');
    const formMessage = document.getElementById('formMessage');
    
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = form.querySelector('.submit-btn');
        const originalText = submitBtn.textContent;
        
        // Clear previous message
        formMessage.className = 'form-message';
        formMessage.textContent = '';
        
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;
        
        // Get form data
        const formData = new FormData(form);
        const data = {
          name: formData.get('name'),
          email: formData.get('email'),
          phone: formData.get('phone') || '',
          message: formData.get('message')
        };
        
        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(data),
          });
          
          if (response.ok) {
            const result = await response.json();
            formMessage.className = 'form-message success';
            formMessage.textContent = result.message || '✓ Message sent successfully! We\'ll get back to you soon.';
            form.reset();
          } else {
            const error = await response.json();
            throw new Error(error.error || 'Failed to send message');
          }
        } catch (error) {
          console.error('Form error:', error);
          formMessage.className = 'form-message error';
          formMessage.innerHTML = `
            <strong>✗ Unable to send message right now.</strong><br><br>
            Please contact us directly:<br>
            📞 <a href="tel:+256742072661" style="color: #991b1b;">0742072661</a> or 
            📞 <a href="tel:+256780288715" style="color: #991b1b;">0780288715</a><br>
            ✉️ <a href="mailto:hello@snd.com" style="color: #991b1b;">hello@snd.com</a>
          `;
        } finally {
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }
      });
    }
  </script>
</BaseLayout>