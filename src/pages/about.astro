---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="About Us — SND | Think It. Create It.">
  <Navbar />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --snd-dark:   #343940;
      --snd-light:  #CFCFD3;
      --snd-black:  #0d0d0d;
      --snd-white:  #ffffff;
      --remi-blue:  #535FFD;
      --remi-amber: #FDAC1B;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'Skia', 'Inter', 'Helvetica Neue', system-ui, sans-serif;
    }

    body {
      background: var(--snd-white);
      color: var(--snd-black);
      font-family: var(--font-body);
      line-height: 1.5;
    }

    /* Hero Tagline */
    .hero-tagline {
      text-align: center;
      padding: 8rem 2rem 3rem;
    }

    .hero-tagline h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 6vw, 5rem);
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }

    .hero-tagline p {
      color: #5f6c7a;
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
    }

    /* Content Sections */
    .about-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 4rem 5rem;
    }

    /* Mission & Vision Section */
    .mission-vision {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      margin-bottom: 5rem;
    }

    .mission-card, .vision-card {
      background: #f9fafb;
      border-radius: 8px;
      padding: 2rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .mission-card:hover, .vision-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px -12px rgba(0,0,0,0.1);
    }

    .mission-card .section-label, .vision-card .section-label {
      color: var(--snd-dark);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      margin-bottom: 1rem;
      font-weight: 600;
      text-transform: uppercase;
      opacity: 0.7;
    }

    .mission-card h2, .vision-card h2 {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .mission-card p, .vision-card p {
      color: #5f6c7a;
      line-height: 1.7;
      font-size: 0.95rem;
    }

    /* Core Operating Areas with Background Images */
    .operating-areas {
      margin-bottom: 5rem;
    }

    .operating-areas .section-label {
      text-align: center;
      color: var(--snd-dark);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      margin-bottom: 1rem;
      font-weight: 600;
      text-transform: uppercase;
      opacity: 0.7;
    }

    .operating-areas h2 {
      text-align: center;
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 3rem;
    }

    .areas-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .area-card {
      position: relative;
      border-radius: 8px;
      padding: 2rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      text-align: center;
      overflow: hidden;
      z-index: 1;
    }

    .area-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.15;
      z-index: -1;
      transition: opacity 0.3s ease, transform 0.5s ease;
    }

    .area-card:hover::before {
      transform: scale(1.05);
      opacity: 0.25;
    }

    .area-card-1::before {
      background-image: url('/tech.jpg');
    }

    .area-card-2::before {
      background-image: url('/art.jpg');
    }

    .area-card-3::before {
      background-image: url('/fashion.jpg');
    }

    .area-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px -12px rgba(0,0,0,0.15);
    }

    .area-icon {
      width: 70px;
      height: 70px;
      background: rgba(255,255,255,0.9);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      position: relative;
      z-index: 2;
    }

    .area-icon img {
      width: 40px;
      height: 40px;
      object-fit: contain;
    }

    .area-card h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--snd-black);
      position: relative;
      z-index: 2;
    }

    .area-card p {
      color: #5f6c7a;
      font-size: 0.9rem;
      line-height: 1.6;
      margin-bottom: 1rem;
      position: relative;
      z-index: 2;
    }

    .area-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--snd-dark);
      background: rgba(255,255,255,0.9);
      padding: 0.2rem 0.8rem;
      border-radius: 8px;
      margin-top: 0.5rem;
      position: relative;
      z-index: 2;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin: 4rem 0;
      padding: 2rem 0;
      border-top: 1px solid var(--snd-light);
      border-bottom: 1px solid var(--snd-light);
    }

    .stat-item {
      text-align: center;
    }

    .stat-number {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--snd-dark);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.85rem;
      color: #8a9bb0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Two Column Layout */
    .two-column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      margin: 4rem 0;
      align-items: center;
    }

    .column-content h3 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--snd-black);
      margin-bottom: 1rem;
    }

    .column-content p {
      color: #5f6c7a;
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    .column-image {
      border-radius: 8px;
      overflow: hidden;
      background: var(--snd-light);
    }

    .column-image img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.4s ease;
    }

    .column-image:hover img {
      transform: scale(1.02);
    }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-tagline { padding: 6rem 1.5rem 2rem; }
      .about-content { padding: 2rem 1.5rem 4rem; }
      .mission-vision { grid-template-columns: 1fr; gap: 1.5rem; }
      .areas-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
      .two-column { grid-template-columns: 1fr; gap: 2rem; }
    }
  </style>

  <!-- Hero Tagline - Think It. Create It. -->
  <div class="hero-tagline">
    <h1>Think It.<br/>Create It.</h1>
    <p>We turn ideas into reality through thoughtful design, innovative development, and genuine collaboration.</p>
  </div>

  <!-- Main Content -->
  <div class="about-content">
    
    <!-- Mission & Vision Section -->
    <div class="mission-vision">
      <div class="vision-card">
        <div class="section-label">OUR VISION</div>
        <h2>To become a leading African brand</h2>
        <p>Building intelligent, creative, and culturally relevant solutions through the integrated disciplines of technology, art, and design. The goal is to demonstrate that world-class digital products and design systems can originate from Uganda and serve both local and global audiences.</p>
      </div>
      <div class="mission-card">
        <div class="section-label">OUR MISSION</div>
        <h2>Simplify complex problems</h2>
        <p>Through thoughtful, well-crafted systems that combine functional design, artificial intelligence, and genuine human understanding. Every product — whether a mobile application, a brand identity, or a physical notebook — must serve a clear purpose and provide a seamless user experience.</p>
      </div>
    </div>

    <!-- Core Operating Areas with Background Images -->
    <div class="operating-areas">
      <div class="section-label">CORE OPERATING AREAS</div>
      <h2>Three Interconnected Domains</h2>
      <div class="areas-grid">
        <div class="area-card area-card-1">
          <div class="area-icon">
            <img src="/icons/technology.svg" alt="Technology" onerror="this.style.display='none'; this.parentNode.innerHTML='📱';" />
          </div>
          <h3>Technology</h3>
          <p>Building applications, tools, and platforms designed to solve real-world organizational and productivity problems. Full-cycle app development from concept through launch and ongoing maintenance. REMI represents the flagship product of this domain.</p>
          <span class="area-tag">Digital Products · REMI · Software Tools</span>
        </div>
        <div class="area-card area-card-2">
          <div class="area-icon">
            <img src="/icons/art.svg" alt="Art & Design" onerror="this.style.display='none'; this.parentNode.innerHTML='🎨';" />
          </div>
          <h3>Art & Design</h3>
          <p>Providing branding, user interface design, visual identity systems, motion graphics, and animation. Every product's user experience, iconography, color palette, and marketing materials are developed with professional design standards.</p>
          <span class="area-tag">Branding · UI/UX · Motion Graphics</span>
        </div>
        <div class="area-card area-card-3">
          <div class="area-icon">
            <img src="/icons/fashion.svg" alt="Fashion & Physical Goods" onerror="this.style.display='none'; this.parentNode.innerHTML='👕';" />
          </div>
          <h3>Fashion & Physical Goods</h3>
          <p>Producing physical merchandise including notebooks and branded apparel. This builds brand visibility when users wear or use SND merchandise in public, and creates an additional revenue channel independent of software subscription models.</p>
          <span class="area-tag">Notebooks · Apparel · Merchandise</span>
        </div>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-number">10+</div>
        <div class="stat-label">Projects Completed</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">15+</div>
        <div class="stat-label">Happy Clients</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">3+</div>
        <div class="stat-label">Years of Experience</div>
      </div>
    </div>

    <!-- Two Column: Our Story -->
    <div class="two-column">
      <div class="column-content">
        <h3>Our Story</h3>
        <p>SND Studio was born from a simple idea: creativity and technology shouldn't exist separately—they should work together to solve real problems and build meaningful, beautiful solutions.</p>
        <p>We are not just a tech company. SND Studio sits at the intersection of art and innovation, where design, fashion, and digital experiences come together as one. Every project we take on reflects this fusion, crafted with purpose, driven by creativity, and powered by technology.</p>
      </div>
      <div class="column-image">
        <img src="/art_tech.jpg" alt="Our workspace" onerror="this.src='https://placehold.co/600x400/e2e8f0/475569?text=Our+Story';" />
      </div>
    </div>

    <!-- Two Column: What We Believe -->
    <div class="two-column">
      <div class="column-image">
        <img src="/believe.jpg" alt="Our philosophy" onerror="this.src='https://placehold.co/600x400/e2e8f0/475569?text=Our+Belief';" />
      </div>
      <div class="column-content">
        <h3>What We Believe</h3>
        <p>We believe every problem can be solved with the right idea. It begins with understanding, a deep, intentional understanding of the people we design for, the challenges they face, and the outcomes they truly value.</p>
        <p>From there, we build with clarity and purpose. We explore, create, test, and refine, shaping each solution until it feels natural, intuitive, and complete.</p>
        <p>We don't stop at what works. We push for what feels right, for the people who will use it, rely on it, and experience it every day.</p>
      </div>
    </div>

  </div>

  <!-- CTA SECTION -->
  <CTA />

  <Footer />
</BaseLayout>