  <!-- CTA SECTION WITH PARALLAX BACKGROUND -->
  <CTA />

  <Footer />

  <script>
    // ── Scroll reveal ──
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });
    reveals.forEach(el => observer.observe(el));

    // ── Navbar scroll ──
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 30);
    });

    // ── PARALLAX: shared rAF-based runner ──
    // Uses requestAnimationFrame so motion is always silky smooth.
    // Speed multiplier controls how far the image travels — higher = more visible effect.
    const HERO_SPEED  = 0.45;   // image moves at 45% of scroll speed — clearly visible
    const CTA_SPEED   = 0.45;

    const heroSection  = document.getElementById('heroParallax');
    const heroBgImage  = document.querySelector('.hero-background');
    const ctaSection   = document.getElementById('ctaParallax');
    const ctaBgImage   = document.querySelector('.cta-bg-image');

    let ticking = false;

    function applyParallax() {
      const scrollY = window.scrollY;

      // ── Hero ──
      if (heroSection && heroBgImage) {
        const rect = heroSection.getBoundingClientRect();
        // Only calculate when section is near the viewport
        if (rect.bottom > 0 && rect.top < window.innerHeight) {
          // How far the top of the section is above the viewport top
          const offset = scrollY - heroSection.offsetTop;
          heroBgImage.style.transform = `translateY(${offset * HERO_SPEED}px)`;
        }
      }

      // ── CTA ──
      if (ctaSection && ctaBgImage) {
        const rect = ctaSection.getBoundingClientRect();
        if (rect.bottom > 0 && rect.top < window.innerHeight) {
          const offset = scrollY - ctaSection.offsetTop;
          ctaBgImage.style.transform = `translateY(${offset * CTA_SPEED}px)`;
        }
      }

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(applyParallax);
        ticking = true;
      }
    }, { passive: true });

    // Run once on load so initial position is correct
    applyParallax();
  </script>

</BaseLayout>